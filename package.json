{
  "name": "ng-gestures-workspace",
  "version": "1.0.0",
  "description": "Gesture library https://github.com/The-PatientZero/ng-gestures",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "ng serve examples-angular",
    "build": "ng build ng-gestures",
    "test": "npm run test:lib && npm run test:examples",
    "test:lib": "jest --config packages/angular/jest.config.ts",
    "test:examples": "jest --config examples/jest.config.ts",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "ci:version": "npm run changeset version && npm install --package-lock-only",
    "ci:publish": "npm run build && npm run changeset publish"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "20.2.0",
    "@angular-eslint/eslint-plugin-template": "20.2.0",
    "@angular-eslint/template-parser": "20.2.0",
    "@angular/build": "20.2.1",
    "@angular/cli": "20.2.1",
    "@angular/compiler-cli": "20.2.3",
    "@angular/language-service": "20.2.3",
    "@changesets/cli": "2.29.6",
    "@playwright/test": "1.55.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.3.0",
    "@typescript-eslint/eslint-plugin": "8.41.0",
    "@typescript-eslint/parser": "8.41.0",
    "@typescript-eslint/utils": "8.41.0",
    "eslint": "9.34.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.2.2",
    "jest": "30.1.2",
    "jest-environment-jsdom": "30.1.2",
    "jest-preset-angular": "15.0.0",
    "ng-packagr": "20.2.0",
    "prettier": "3.6.2",
    "ts-jest": "29.4.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@angular/common": "20.2.3",
    "@angular/compiler": "20.2.3",
    "@angular/core": "20.2.3",
    "@angular/platform-browser": "20.2.3",
    "@angular/router": "20.2.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  }
}
